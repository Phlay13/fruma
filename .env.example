# Fruma — HyperEVM (chain 999)
# Primary RPC: get a free Alchemy key at https://dashboard.alchemy.com (enable "Hyperliquid" app)
# 30M compute units/month free — plenty for this bot.
RPC_URL=https://hyperliquid-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Fallbacks (free, no signup) — official is 100 req/min, dRPC public best-effort
RPC_FALLBACK_1=https://rpc.hyperliquid.xyz/evm
RPC_FALLBACK_2=https://hyperliquid.drpc.org

# Phase 1 is read-only: no private key needed yet.
# PRIVATE_KEY=

DRY_RUN=true
MIN_PROFIT_USD=0.50

# Scan cadence (ms). Official RPC caps at 100 req/min — keep >= 15000 if not on Alchemy.
POLL_INTERVAL_MS=8000
